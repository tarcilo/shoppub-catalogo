# Token do endpoint de sync diário (/api/sync). Gere um valor aleatório.
# Na Cloudflare, defina como secret: npx wrangler secret put SYNC_TOKEN
SYNC_TOKEN=

# Segredo para assinar a sessão do painel (HMAC). Gere com: openssl rand -hex 32
# Produção: npx wrangler secret put SESSION_SECRET
SESSION_SECRET=

# Senha do super admin do painel (login com um e-mail SUPER_ADMINS + esta senha).
# Produção: npx wrangler secret put ADMIN_PASSWORD
ADMIN_PASSWORD=
# Opcional: e-mails super admin além do padrão, separados por vírgula.
# SUPER_ADMINS=outro@shoppub.com.br
