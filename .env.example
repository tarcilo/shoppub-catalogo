# Token do endpoint de sync diário (/api/sync). Gere um valor aleatório.
# Na Cloudflare, defina como secret: npx wrangler secret put SYNC_TOKEN
SYNC_TOKEN=

# Resend (envio do magic link do painel — Fase 2).
# Produção: npx wrangler secret put RESEND_API_KEY  (NÃO commitar a chave)
# Dev local: coloque o valor real só no .env.local (que é gitignored)
RESEND_API_KEY=
# Remetente verificado no Resend (ex: catalogo@shoppub.io)
RESEND_FROM=
